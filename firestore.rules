rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ToolsHub Security Rules
    // Only allow users to read and write their own data.
    // This matches the `users/{userId}` document and all subcollections
    // like `conversations`, `messages`, `usage`, and `toolHistory`.
    
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId && !('subscription' in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    match /proWaitlist/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
