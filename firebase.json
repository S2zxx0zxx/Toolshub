  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",

    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "security_rules_test_firestore/**",
      "**/*.bat",
      "**/*.py",
      "**/*.ipynb",
      "**/*.sh",
      "**/*.exe",
      "worker/**",
      "scripts/**",
      "test.js",
      "restore.ipynb",
      "extract_styles.py",
      "process_icon.py"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "emulators": {

    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
